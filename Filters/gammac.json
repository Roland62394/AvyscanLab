{
  "Id": "gammac",
  "Name": "GamMac",
  "Dlls": [],
  "Scripts": [],
  "Code": "if (FunctionExists(\"GamMac\")) {\n  try {\n    base_pix = PixelType(c)\n    mx  = _MatrixAuto(c)\n    rgb = EnsureColorspaceSafe(c, \"RGB24\", matrix=mx)\n    _gx = Min({X}, Width(rgb)-1)\n    _gy = Min({Y}, Height(rgb)-1)\n    _gw = ({W} > 0) ? Min({W}, Width(rgb)-_gx) : 0\n    _gh = ({H} > 0) ? Min({H}, Height(rgb)-_gy) : 0\n    rgb = GamMac(rgb,\n      \\ LockChan={LockChan}, LockVal={LockVal},\n      \\ x=_gx, y=_gy, w=_gw, h=_gh,\n      \\ Scale={Scale}, Th={Th}, HiTh={HiTh},\n      \\ Omin={Omin}, Omax={Omax}, Show={Show}, Verbosity={Verbosity})\n    c = EnsureColorspaceSafe(rgb, base_pix, matrix=mx)\n  } catch(err) { pipeline_err = \"GamMac: \" + err }\n}",
  "Position": "GamMac",
  "RegionDraw": true,
  "Controls": [
    {
      "Placeholder": "LockChan",
      "Type": "slider",
      "Default": "1",
      "Description": "Channel to lock. -3=none, -2=min, -1=max, 0=R, 1=G, 2=B",
      "Min": -3,
      "Max": 2,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "LockVal",
      "Type": "slider",
      "Default": "250",
      "Description": "Target value for the locked channel (1-255)",
      "Min": 1,
      "Max": 255,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Scale",
      "Type": "slider",
      "Default": "2",
      "Description": "Analysis scale. 0=frame, 1=region, 2=adaptive (recommended)",
      "Max": 2,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Th",
      "Type": "slider",
      "Default": "0.12",
      "Description": "Low threshold for color correction. Below this, no correction applied",
      "Max": 1,
      "Step": 0.01,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "HiTh",
      "Type": "slider",
      "Default": "0.25",
      "Description": "High threshold. Above this, full correction. Between Th and HiTh = gradual blend",
      "Max": 1,
      "Step": 0.01,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "X",
      "Type": "slider",
      "Default": "0",
      "Description": "Analysis region left position (0 = full frame). Draw on video to set",
      "ScaleWithPreview": true,
      "Max": 10000,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Y",
      "Type": "slider",
      "Default": "0",
      "Description": "Analysis region top position (0 = full frame). Draw on video to set",
      "ScaleWithPreview": true,
      "Max": 10000,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "W",
      "Type": "slider",
      "Default": "0",
      "Description": "Analysis region width (0 = full width). Draw on video to set",
      "ScaleWithPreview": true,
      "Max": 10000,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "H",
      "Type": "slider",
      "Default": "0",
      "Description": "Analysis region height (0 = full height). Draw on video to set",
      "ScaleWithPreview": true,
      "Max": 10000,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Omin",
      "Type": "slider",
      "Default": "0",
      "Description": "Output minimum level. Clamps dark values (0 = no clamp)",
      "Max": 255,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Omax",
      "Type": "slider",
      "Default": "255",
      "Description": "Output maximum level. Clamps bright values (255 = no clamp)",
      "Max": 255,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Show",
      "Type": "checkbox",
      "Default": "false",
      "Description": "Overlay analysis info on the image (debug mode)",
      "Max": 100,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    },
    {
      "Placeholder": "Verbosity",
      "Type": "slider",
      "Default": "4",
      "Description": "Debug info detail level (0=none, 6=maximum). Only visible when Show=true",
      "Max": 6,
      "Step": 1,
      "Options": [],
      "OnValue": "true",
      "OffValue": "false"
    }
  ]
}
