<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CleanScan.App"
             xmlns:local="using:CleanScan"
             RequestedThemeVariant="Dark">
             <!-- Force dark variant to keep Fluent popups/menu surfaces readable with this app's dark custom styles. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
