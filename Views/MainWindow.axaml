<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CleanScan.ViewModels"
        xmlns:local="using:CleanScan.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="400"
        x:Class="CleanScan.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Ico.ico"
        Title="CleanScan"
        Background="{DynamicResource BgDeep}"
        Width="960"
        MinWidth="700"
        MinHeight="500"
        KeyDown="OnWindowKeyDown">

    <Window.Resources>
        <!-- ─── Colors ─── -->
        <SolidColorBrush x:Key="BgDeep"        Color="#0F1319"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#161B24"/>
        <SolidColorBrush x:Key="BgHeader"      Color="#1C2333"/>
        <SolidColorBrush x:Key="BgInput"       Color="#1A2030"/>
        <SolidColorBrush x:Key="BorderSubtle"  Color="#252E42"/>
        <SolidColorBrush x:Key="BorderAccent"  Color="#2E3D5A"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#7984A5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#DBDBDB"/>
        <SolidColorBrush x:Key="TextLabel"     Color="#F6F6F6"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#3B82C4"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#35C156"/>
        <SolidColorBrush x:Key="AccentDimmed"  Color="#1E3A2E"/>
        <SolidColorBrush x:Key="BgHover"       Color="#243050"/>
        <SolidColorBrush x:Key="BgPressed"     Color="#1a2540"/>
        <SolidColorBrush x:Key="AccentHover"   Color="#5BA5E4"/>
        <SolidColorBrush x:Key="AccentPressed" Color="#2870B8"/>
    </Window.Resources>

    <Window.Styles>

        <!-- ─── Global text ─── -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource TextLabel}"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Consolas,Cascadia Code,monospace"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ─── TextBox ─── -->
        <Style Selector="TextBox">
            <Setter Property="Background"               Value="{DynamicResource BgInput}"/>
            <Setter Property="Foreground"               Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CornerRadius"             Value="3"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontFamily"               Value="Consolas,Cascadia Code,monospace"/>
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="Padding"                  Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment"            Value="Right"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource AccentBlue}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderAccent}"/>
        </Style>

        <!-- ─── ComboBox ─── -->
        <Style Selector="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource BgInput}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Consolas,Cascadia Code,monospace"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="MinWidth"        Value="130"/>
        </Style>

        <!-- ─── Toggle button ─── -->
        <Style Selector="Button.toggle">
            <Setter Property="Height"                     Value="30"/>
            <Setter Property="Padding"                    Value="8,0"/>
            <Setter Property="CornerRadius"               Value="4"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="BorderBrush"                Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Background"                 Value="{DynamicResource BgHeader}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontFamily"                 Value="Consolas,Cascadia Code,monospace"/>
            <Setter Property="FontWeight"                 Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.toggle:pointerover">
            <Setter Property="Background"  Value="{DynamicResource BgHover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextLabel}"/>
        </Style>
        <Style Selector="Button.toggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextLabel}"/>
        </Style>
        <Style Selector="Button.toggle:pressed">
            <Setter Property="Background"  Value="{DynamicResource BgPressed}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextLabel}"/>
        </Style>
        <Style Selector="Button.toggle:pressed /template/ ContentPresenter">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextLabel}"/>
        </Style>

        <!-- ─── Expand arrow button ─── -->
        <Style Selector="Button.expand-btn">
            <Setter Property="Width"                      Value="28"/>
            <Setter Property="Height"                     Value="30"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="CornerRadius"               Value="3"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="BorderBrush"                Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{DynamicResource TextLabel}"/>
            <Setter Property="FontSize"                   Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.expand-btn:pointerover">
            <Setter Property="Background"  Value="{DynamicResource BgHover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentBlue}"/>
        </Style>
        <Style Selector="Button.expand-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background"             Value="{DynamicResource BgHover}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBlue}"/>
        </Style>
        <Style Selector="Button.expand-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource BgPressed}"/>
        </Style>
        <Style Selector="Button.expand-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background"             Value="{DynamicResource BgPressed}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBlue}"/>
        </Style>
        <Style Selector="Button.expand-btn.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentGreen}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.expand-btn.active /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.expand-btn.active:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentGreen}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.expand-btn.active:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.expand-btn.active:pressed /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentGreen}"/>
        </Style>

        <!-- ─── Menu ─── -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="{DynamicResource BgHeader}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLabel}"/>
        </Style>
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource BgHeader}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLabel}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontFamily" Value="Consolas,Cascadia Code,monospace"/>
            <Setter Property="Height"     Value="32"/>
            <Setter Property="Padding"    Value="12,0"/>
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLabel}"/>
        </Style>
        <Style Selector="MenuItem:selected">
            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLabel}"/>
        </Style>

        <!-- ─── Param row label ─── -->
        <Style Selector="TextBlock.param-label">
            <Setter Property="Width"      Value="100"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLabel}"/>
        </Style>

        <!-- ─── Section title ─── -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin"        Value="0,0,0,10"/>
        </Style>

        <!-- ─── Group label ─── -->
        <Style Selector="TextBlock.group-label">
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextLabel}"/>
            <Setter Property="Margin"        Value="0,0,0,6"/>
        </Style>

        <!-- ─── Transport button (barre lecteur VirtualDub) ─── -->
        <Style Selector="Button.transport">
            <Setter Property="Width"                      Value="34"/>
            <Setter Property="Height"                     Value="32"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="CornerRadius"               Value="5"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="BorderBrush"                Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="Background"                 Value="{DynamicResource BgInput}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource TextLabel}"/>
            <Setter Property="FontSize"                   Value="14"/>
            <Setter Property="FontFamily"                 Value="Consolas,Cascadia Code,monospace"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.transport:pointerover">
            <Setter Property="Background"  Value="{DynamicResource BgHover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground"  Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.transport:pointerover /template/ ContentPresenter">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.transport:pressed">
            <Setter Property="Background"  Value="{DynamicResource BgPressed}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
        </Style>
        <Style Selector="Button.transport:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Play variant -->
        <Style Selector="Button.transport.play">
            <Setter Property="Width"       Value="52"/>
            <Setter Property="FontSize"    Value="17"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentGreen}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.transport.play:pointerover">
            <Setter Property="Background"  Value="{DynamicResource AccentDimmed}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentGreen}"/>
            <Setter Property="Foreground"  Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.transport.play:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentGreen}"/>
        </Style>
        <Style Selector="Button.transport.play:pressed /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentGreen}"/>
        </Style>

        <!-- ─── Param slider ─── -->
        <Style Selector="Slider.param-slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="Slider">
                    <!-- Background transparent = zone cliquable sur toute la hauteur -->
                    <Grid Background="Transparent" VerticalAlignment="Center">
                        <!-- piste grise de fond -->
                        <Border Height="3" VerticalAlignment="Center"
                                Background="{DynamicResource BorderAccent}"
                                CornerRadius="2"
                                IsHitTestVisible="False"/>
                        <Track Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}"
                               IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                               Orientation="Horizontal">
                            <Track.DecreaseButton>
                                <!-- IsHitTestVisible=False : on gère l'interaction en code-behind -->
                                <RepeatButton Name="PART_DecreaseButton" IsHitTestVisible="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Height="3" VerticalAlignment="Center"
                                                    Background="{DynamicResource AccentBlue}"
                                                    CornerRadius="2 0 0 2"
                                                    IsHitTestVisible="False"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.IncreaseButton>
                                <RepeatButton Name="PART_IncreaseButton" IsHitTestVisible="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border IsHitTestVisible="False"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                            <Thumb Name="PART_Thumb" IsHitTestVisible="False">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Ellipse Width="14" Height="14"
                                                 Fill="{DynamicResource AccentBlue}"
                                                 Stroke="{DynamicResource BgDeep}"
                                                 StrokeThickness="2"
                                                 IsHitTestVisible="False"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <!-- États hover/pressed sur la poignée -->
        <Style Selector="Slider.param-slider /template/ Thumb:pointerover Ellipse">
            <Setter Property="Fill" Value="{DynamicResource AccentHover}"/>
        </Style>
        <Style Selector="Slider.param-slider /template/ Thumb:pressed Ellipse">
            <Setter Property="Fill" Value="{DynamicResource AccentPressed}"/>
        </Style>


        <!-- ─── Guided tour target highlight ─── -->
        <Style Selector="Button.tour-highlight">
            <Setter Property="BorderBrush" Value="#5BA0F5"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Background" Value="#1A3A6B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.35"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Slider.tour-highlight /template/ Thumb Ellipse">
            <Setter Property="Fill" Value="#8AB8FF"/>
            <Setter Property="Stroke" Value="#FFFFFF"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
        <Style Selector="Slider.tour-highlight /template/ RepeatButton#PART_DecreaseButton Border">
            <Setter Property="Background" Value="#6AA3D8"/>
        </Style>
        <Style Selector="Slider.tour-highlight">
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.35"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="TextBlock.tour-highlight">
            <Setter Property="Foreground" Value="#8AB8FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.35"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- ══════════════════════════════════════════════════════════
         ROOT LAYOUT
    ══════════════════════════════════════════════════════════ -->
    <DockPanel Background="{DynamicResource BgDeep}">

        <!-- ── TOP BAR ── -->
        <Border x:Name="TopBar" DockPanel.Dock="Top"
                Background="{DynamicResource BgHeader}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="0">

                <!-- Menu strip -->
                <Border Background="{DynamicResource BgHeader}" Padding="0">
                    <Menu x:Name="MainMenu" HorizontalAlignment="Stretch">
                        <Menu.ItemsPanel>
                            <ItemsPanelTemplate>
                                <DockPanel LastChildFill="False" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </Menu.ItemsPanel>
                        <MenuItem x:Name="InfosMenu" Header="Infos">
                            <MenuItem x:Name="UserGuideMenuItem"     Header="User guide"     Click="OnUserGuideClick"/>
                            <MenuItem x:Name="ScriptPreviewMenuItem" Header="Script preview" Click="OnScriptPreviewClick"/>
                            <MenuItem x:Name="GuidedTourMenuItem"    Header="Guided tour"    Click="OnGuidedTourClick"/>
                        </MenuItem>
                        <MenuItem x:Name="PresetMenuItem" Header="Preset" Click="OnPresetClick"/>
                        <MenuItem x:Name="SettingsMenu" Header="Settings">
                            <MenuItem StaysOpenOnClick="True" Focusable="False">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <TextBlock x:Name="ThreadsLabel" Text="threads" VerticalAlignment="Center"/>
                                        <TextBox x:Name="threads" Width="44" TextAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem StaysOpenOnClick="True" Focusable="False">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <TextBlock x:Name="SourceLoaderLabel" Text="Source loader" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="ForceSourceCombo" MinWidth="120"
                                                  SelectionChanged="OnForceSourceChanged">
                                            <ComboBoxItem Content="Auto"     Tag=""/>
                                            <ComboBoxItem Content="FFMS2"    Tag="FFMS2"/>
                                            <ComboBoxItem Content="L-SMASH"  Tag="LSMASH"/>
                                            <ComboBoxItem Content="LWLibav"  Tag="LWLIBAV"/>
                                        </ComboBox>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <!-- Theme selector -->
                            <MenuItem StaysOpenOnClick="True" Focusable="False">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <TextBlock x:Name="ThemeLabel" Text="Theme" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button x:Name="ThemeDarkBtn" Content="Dark" Tag="Dark"
                                                    Click="OnThemeClick" Padding="6,3" FontSize="11"
                                                    Background="Transparent" Foreground="{DynamicResource TextLabel}"
                                                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="3"
                                                    Cursor="Hand" FontFamily="Consolas,Cascadia Code,monospace"/>
                                            <Button x:Name="ThemeLightBtn" Content="Light" Tag="Light"
                                                    Click="OnThemeClick" Padding="6,3" FontSize="11"
                                                    Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="3"
                                                    Cursor="Hand" FontFamily="Consolas,Cascadia Code,monospace"/>
                                        </StackPanel>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <!-- Accent color selector -->
                            <MenuItem StaysOpenOnClick="True" Focusable="False">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <TextBlock x:Name="AccentLabel" Text="Accent" VerticalAlignment="Center"/>
                                        <StackPanel x:Name="AccentSwatchPanel" Orientation="Horizontal" Spacing="4"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="ResetSettingsMenuItem" Header="Reset settings" Click="OnResetSettingsClick"/>
                        </MenuItem>
                        <MenuItem x:Name="FeedbackMenuItem" Header="Feedback" Click="OnFeedbackClick"/>
                        <MenuItem x:Name="AboutMenuItem" Header="A propos" DockPanel.Dock="Right" Click="OnAboutClick"/>
                        <MenuItem x:Name="LanguagesMenu" Header="Language" DockPanel.Dock="Right">
                            <MenuItem x:Name="LanguageEnglishMenuItem" Header="English"  Tag="en" Click="OnLanguageClick"/>
                            <MenuItem x:Name="LanguageFrenchMenuItem"  Header="Français" Tag="fr" Click="OnLanguageClick"/>
                            <MenuItem x:Name="LanguageGermanMenuItem"  Header="Deutsch"  Tag="de" Click="OnLanguageClick"/>
                            <MenuItem x:Name="LanguageSpanishMenuItem" Header="Español"  Tag="es" Click="OnLanguageClick"/>
                        </MenuItem>
                    </Menu>
                </Border>

                <!-- Source row -->
                <Border Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="0,1,0,0"
                        Padding="12,7">
                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <!-- SOURCE label -->
                        <TextBlock Grid.Column="0" Text="SOURCE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Top" Margin="0,5,8,0"/>

                        <!-- Clip tabs (wrappable) -->
                        <Border Grid.Column="1" x:Name="ClipTabsContainer"
                                Background="Transparent"
                                DragDrop.AllowDrop="True">
                            <WrapPanel x:Name="ClipTabsPanel" Orientation="Horizontal">
                                <Button x:Name="AddClipBtn" Content="+" FontSize="16"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextSecondary}"
                                        BorderBrush="{DynamicResource BorderSubtle}"
                                        BorderThickness="1" Padding="8,2"
                                        MinWidth="28" MinHeight="26"
                                        HorizontalContentAlignment="Center"
                                        Cursor="Hand" VerticalAlignment="Center"
                                        Margin="0,0,0,4"
                                        ToolTip.Tip="Add clip(s)"
                                        Click="OnAddClipClick"/>
                            </WrapPanel>
                        </Border>
                        <TextBox x:Name="source" IsVisible="False" Width="0" Grid.Column="1"/>

                        <!-- Image sequence / fps fields -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16"
                                    VerticalAlignment="Top" Margin="8,0,0,0">
                            <StackPanel x:Name="img_start_panel" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="start" FontSize="10" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                <TextBox x:Name="img_start" Width="60"/>
                            </StackPanel>
                            <StackPanel x:Name="img_end_panel" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="end" FontSize="10" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                <TextBox x:Name="img_end" Width="60"/>
                            </StackPanel>
                            <StackPanel x:Name="play_speed_panel" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="fps" FontSize="10" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                <TextBox x:Name="play_speed" Width="44"/>
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             ZONE CENTRALE — vidéo + timeline (fixe) + séparateur + panneau bas
        ══════════════════════════════════════════════════════ -->
        <Grid x:Name="MainGrid" RowDefinitions="*,4,360">

        <!-- ── Row 0 : DockPanel — Transport Bar (fixe) + Vidéo (fill) ── -->
        <DockPanel Grid.Row="0">

            <!-- Transport Bar fixée en bas du bloc vidéo -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BgHeader}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0,16,16">
                <StackPanel Spacing="3">

                    <!-- Slider de position + temps -->
                    <Grid ColumnDefinitions="*,10,Auto">
                        <Slider x:Name="SeekBar" Grid.Column="0"
                                Minimum="0" Maximum="1" Value="0"
                                IsEnabled="False"
                                MaxWidth="800"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="0">
                            <TextBlock x:Name="FrameLabel"
                                       Text="– / –"
                                       FontFamily="Consolas,Cascadia Code,monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       MinWidth="110"/>
                            <TextBlock x:Name="TimeLabel"
                                       Text="–:–– / –:––"
                                       FontFamily="Consolas,Cascadia Code,monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       MinWidth="110"/>
                        </StackPanel>
                    </Grid>

                    <!-- Boutons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="5">
                        <Button x:Name="VdbBeginning" Classes="transport" Content="|◀" FontSize="12"
                                ToolTip.Tip="Beginning  (Ctrl+←)" Click="OnVdbBeginningClick"/>
                        <Button x:Name="VdbPrevFrame" Classes="transport" Content="◀◀"
                                ToolTip.Tip="Prev frame  (←)" Click="OnVdbPrevFrameClick"/>
                        <Rectangle Width="1" Height="22" Fill="{DynamicResource BorderSubtle}" Margin="4,0"/>
                        <Button x:Name="VdbPlay" Classes="transport play" Content="▶"
                                ToolTip.Tip="Play  (Space)" Click="OnVdbPlayClick"/>
                        <Rectangle Width="1" Height="22" Fill="{DynamicResource BorderSubtle}" Margin="4,0"/>
                        <Button x:Name="VdbNextFrame" Classes="transport" Content="▶▶"
                                ToolTip.Tip="Next frame  (→)" Click="OnVdbNextFrameClick"/>
                        <Button x:Name="VdbEnd" Classes="transport" Content="▶|" FontSize="12"
                                ToolTip.Tip="End  (Ctrl+→)" Click="OnVdbEndClick"/>
                        <Rectangle Width="1" Height="22" Fill="{DynamicResource BorderSubtle}" Margin="4,0"/>
                        <Button x:Name="SpeedBtn" Classes="transport" Content="1x"
                                FontSize="10" Width="38"
                                ToolTip.Tip="Playback speed" Click="OnSpeedClick"/>
                        <Button x:Name="HalfResBtn" Classes="transport" Content="½"
                                FontSize="24" Width="34"
                                ToolTip.Tip="Half-resolution preview" Click="OnHalfResClick"/>
                        <Button x:Name="MaxViewerBtn" Classes="transport" Content="⛶"
                                FontSize="16" Width="34"
                                ToolTip.Tip="Maximize viewer (F11)"
                                ToolTip.ShowDelay="1000"
                                Click="OnMaxViewerClick"/>
                        <Rectangle Width="1" Height="22" Fill="{DynamicResource BorderSubtle}" Margin="8,0"/>
                        <ComboBox x:Name="ClipPresetCombo"
                                  MinWidth="130" MaxWidth="220"
                                  FontSize="11" Padding="8,3"
                                  Background="{DynamicResource BgInput}"
                                  BorderBrush="{DynamicResource BorderSubtle}"
                                  Foreground="{DynamicResource TextPrimary}"
                                  VerticalAlignment="Center"
                                  PlaceholderText="Preset (ce clip)"
                                  SelectionChanged="OnClipPresetChanged"
                                  ToolTip.Tip="Appliquer un preset uniquement à ce clip"/>
                        <Rectangle Width="1" Height="22" Fill="{DynamicResource BorderSubtle}" Margin="8,0"/>
                        <Button x:Name="RecordBtn" Classes="transport" Content="⏺ Record"
                                FontSize="12" MinWidth="120" Padding="16,4"
                                ToolTip.Tip="Record" Click="OnRecordClick"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Drop hint (above player, blinks) -->
            <TextBlock x:Name="DropHintBar"
                       Text="&#x25BC;  Glisse ton fichier ici  &#x25BC;"
                       FontSize="17" FontWeight="SemiBold"
                       Foreground="#FFD54F"
                       Background="{DynamicResource BgDeep}"
                       HorizontalAlignment="Center"
                       Padding="16,4"
                       DockPanel.Dock="Top">
                <TextBlock.Styles>
                    <Style Selector="TextBlock#DropHintBar">
                        <Style.Animations>
                            <Animation Duration="0:0:1" IterationCount="INFINITE"
                                       PlaybackDirection="Alternate">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="0.2"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </TextBlock.Styles>
            </TextBlock>

            <!-- Lecteur vidéo mpv — remplit l'espace restant -->
            <Border Background="Black" MinHeight="100">
                <Grid>
                    <local:MpvHost x:Name="VideoHost"/>
<Border x:Name="PlayerErrorBanner" IsVisible="False"
                            Background="#DD111111" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" Padding="16,12">
                        <TextBlock x:Name="PlayerErrorText"
                                   Foreground="#FFEEEEEE" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

        </DockPanel>

        <!-- ── Row 1 : Séparateur redimensionnable (vidéo ↕ panneau bas) ── -->
        <GridSplitter x:Name="MainSplitter" Grid.Row="1"
                      ResizeDirection="Rows"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderSubtle}"
                      Cursor="SizeNorthSouth"/>

        <!-- ── Row 2 : OPTIONS / FILTERS / PARAMS ── -->
        <Border x:Name="BottomPanel" Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" MinWidth="120"/>  <!-- Colonne boutons toggle -->
                    <ColumnDefinition Width="5"/>                   <!-- Séparateur -->
                    <ColumnDefinition Width="*"/>                   <!-- Colonne réglages filtre -->
                </Grid.ColumnDefinitions>

                <!-- ════ COL 0 — OPTIONS + FILTERS (boutons toggle) ════ -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <DockPanel Margin="10,10,20,10">

                            <!-- OPTIONS -->
                            <StackPanel DockPanel.Dock="Top" Spacing="3" Margin="0,0,0,8">
                                <TextBlock Classes="group-label" Text="OPTIONS"/>
                                <Button x:Name="preview"       Classes="toggle"
                                        HorizontalAlignment="Stretch" Click="OnOptionToggleButtonClick"/>
                                <Button x:Name="enable_flip_h" Classes="toggle"
                                        HorizontalAlignment="Stretch" Click="OnOptionToggleButtonClick"/>
                                <Button x:Name="enable_flip_v" Classes="toggle"
                                        HorizontalAlignment="Stretch" Click="OnOptionToggleButtonClick"/>
                            </StackPanel>

                            <Rectangle DockPanel.Dock="Top"
                                       Height="1" Fill="{DynamicResource BorderSubtle}"
                                       Margin="0,0,0,8"/>

                            <!-- FILTERS -->
                            <StackPanel DockPanel.Dock="Top" Spacing="4">
                                <TextBlock Classes="group-label" Text="FILTERS"/>

                                <Grid ColumnDefinitions="*,10,28">
                                    <Button Grid.Column="0" x:Name="enable_crop"
                                            Classes="toggle" HorizontalAlignment="Stretch"
                                            Click="OnOptionToggleButtonClick"/>
                                    <Button Grid.Column="2" x:Name="CropExpandBtn"
                                            Classes="expand-btn" Content="▶"
                                            Click="OnExpandButtonClick" Tag="CropParams"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,10,28">
                                    <Button Grid.Column="0" x:Name="enable_gammac"
                                            Classes="toggle" HorizontalAlignment="Stretch"
                                            Click="OnOptionToggleButtonClick"/>
                                    <Button Grid.Column="2" x:Name="GammacExpandBtn"
                                            Classes="expand-btn" Content="▶"
                                            Click="OnExpandButtonClick" Tag="GammacParams"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,10,28">
                                    <Button Grid.Column="0" x:Name="enable_denoise"
                                            Classes="toggle" HorizontalAlignment="Stretch"
                                            Click="OnOptionToggleButtonClick"/>
                                    <Button Grid.Column="2" x:Name="DenoiseExpandBtn"
                                            Classes="expand-btn" Content="▶"
                                            Click="OnExpandButtonClick" Tag="DenoiseParams"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,10,28">
                                    <Button Grid.Column="0" x:Name="enable_degrain"
                                            Classes="toggle" HorizontalAlignment="Stretch"
                                            Click="OnOptionToggleButtonClick"/>
                                    <Button Grid.Column="2" x:Name="DegrainExpandBtn"
                                            Classes="expand-btn" Content="▶"
                                            Click="OnExpandButtonClick" Tag="DegrainParams"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,10,28">
                                    <Button Grid.Column="0" x:Name="enable_luma_levels"
                                            Classes="toggle" HorizontalAlignment="Stretch"
                                            Click="OnOptionToggleButtonClick"/>
                                    <Button Grid.Column="2" x:Name="LumaExpandBtn"
                                            Classes="expand-btn" Content="▶"
                                            Click="OnExpandButtonClick" Tag="LumaParams"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,10,28">
                                    <Button Grid.Column="0" x:Name="enable_sharp"
                                            Classes="toggle" HorizontalAlignment="Stretch"
                                            Click="OnOptionToggleButtonClick"/>
                                    <Button Grid.Column="2" x:Name="SharpExpandBtn"
                                            Classes="expand-btn" Content="▶"
                                            Click="OnExpandButtonClick" Tag="SharpParams"/>
                                </Grid>
                            </StackPanel>

                            <Rectangle DockPanel.Dock="Top"
                                       Height="1" Fill="{DynamicResource BorderSubtle}"
                                       Margin="0,8,0,8"/>

                            <!-- CUSTOM FILTERS -->
                            <StackPanel DockPanel.Dock="Top" Spacing="4">
                                <Grid ColumnDefinitions="*,Auto,4,Auto">
                                    <TextBlock Grid.Column="0" Classes="group-label" Text="CUSTOM"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" x:Name="ImportCustomFilterBtn"
                                            Content="&#x2193;"
                                            FontSize="13" FontWeight="Bold"
                                            Width="24" Height="22"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Background="{DynamicResource BgHeader}"
                                            Foreground="{DynamicResource TextPrimary}"
                                            BorderBrush="{DynamicResource BorderSubtle}"
                                            BorderThickness="1"
                                            ToolTip.Tip="Import"
                                            Click="OnImportCustomFilterClick"/>
                                    <Button Grid.Column="3" x:Name="AddCustomFilterBtn"
                                            Content="+"
                                            FontSize="14" FontWeight="Bold"
                                            Width="24" Height="22"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Background="{DynamicResource BgHeader}"
                                            Foreground="{DynamicResource TextPrimary}"
                                            BorderBrush="{DynamicResource BorderSubtle}"
                                            BorderThickness="1"
                                            Click="OnAddCustomFilterClick"/>
                                </Grid>
                                <StackPanel x:Name="CustomFiltersList" Spacing="4"/>
                            </StackPanel>

                        </DockPanel>
                    </ScrollViewer>
                </Border>

                <!-- ════ COL 1 — Séparateur redimensionnable ════ -->
                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource BorderSubtle}"
                              Cursor="SizeWestEast"/>

                <!-- ════ COL 2 — RÉGLAGES des filtres (multi-colonnes) ════ -->
                <Border Grid.Column="2" Background="{DynamicResource BgPanel}">
                    <Grid>
                        <TextBlock x:Name="ParamsPlaceholder"
                                   IsVisible="True"
                                   Text="← select a filter"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Opacity="0.4"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Horizontal">

                                <!-- ── CROP ── -->
                                <Border x:Name="CropParams" IsVisible="False"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
                                        Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="section-title" Text="CROP"/>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Crop_L" Classes="param-label" Text="Crop_L" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Crop_L" Classes="param-slider" Minimum="0" Maximum="500" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Crop_L" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Crop_T" Classes="param-label" Text="Crop_T" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Crop_T" Classes="param-slider" Minimum="0" Maximum="500" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Crop_T" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Crop_R" Classes="param-label" Text="Crop_R" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Crop_R" Classes="param-slider" Minimum="0" Maximum="500" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Crop_R" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Crop_B" Classes="param-label" Text="Crop_B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Crop_B" Classes="param-slider" Minimum="0" Maximum="500" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Crop_B" Width="70"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── DEGRAIN ── -->
                                <Border x:Name="DegrainParams" IsVisible="False"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
                                        Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="section-title" Text="DEGRAIN"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_degrain_preset" Classes="param-label" Text="preset"/>
                                            <ComboBox x:Name="degrain_preset"/>
                                        </StackPanel>
                                        <Separator Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_degrain_mode" Classes="param-label" Text="mode"/>
                                            <ComboBox x:Name="degrain_mode"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_degrain_thSAD" Classes="param-label" Text="thSAD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_degrain_thSAD" Classes="param-slider" Minimum="0" Maximum="1000" SmallChange="10"/>
                                            <TextBox Grid.Column="2" x:Name="degrain_thSAD" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_degrain_thSADC" Classes="param-label" Text="thSADC" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_degrain_thSADC" Classes="param-slider" Minimum="0" Maximum="1000" SmallChange="10"/>
                                            <TextBox Grid.Column="2" x:Name="degrain_thSADC" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_degrain_blksize" Classes="param-label" Text="blksize" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_degrain_blksize" Classes="param-slider" Minimum="4" Maximum="64" SmallChange="4"/>
                                            <TextBox Grid.Column="2" x:Name="degrain_blksize" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_degrain_overlap" Classes="param-label" Text="overlap" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_degrain_overlap" Classes="param-slider" Minimum="0" Maximum="32" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="degrain_overlap" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_degrain_pel" Classes="param-label" Text="pel" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_degrain_pel" Classes="param-slider" Minimum="1" Maximum="4" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="degrain_pel" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_degrain_search" Classes="param-label" Text="search" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_degrain_search" Classes="param-slider" Minimum="0" Maximum="5" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="degrain_search" Width="70"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_degrain_prefilter" Classes="param-label" Text="prefilter"/>
                                            <ComboBox x:Name="degrain_prefilter"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ── DENOISE ── -->
                                <Border x:Name="DenoiseParams" IsVisible="False"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
                                        Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="section-title" Text="DENOISE"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_denoise_preset" Classes="param-label" Text="preset"/>
                                            <ComboBox x:Name="denoise_preset"/>
                                        </StackPanel>
                                        <Separator Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_denoise_mode" Classes="param-label" Text="mode"/>
                                            <ComboBox x:Name="denoise_mode"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_denoise_strength" Classes="param-label" Text="strength" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_denoise_strength" Classes="param-slider" Minimum="1" Maximum="24" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="denoise_strength" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_denoise_dist" Classes="param-label" Text="dist" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_denoise_dist" Classes="param-slider" Minimum="1" Maximum="20" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="denoise_dist" Width="70"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_denoise_grey" Classes="param-label" Text="grey"/>
                                            <Button x:Name="denoise_grey" Width="70" Classes="toggle" Click="OnOptionToggleButtonClick"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ── LUMA LEVELS ── -->
                                <Border x:Name="LumaParams" IsVisible="False"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
                                        Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="section-title" Text="LUMA LEVELS"/>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Lum_Bright" Classes="param-label" Text="Bright" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Lum_Bright" Classes="param-slider" Minimum="-255" Maximum="255" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Lum_Bright" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Lum_Contrast" Classes="param-label" Text="Contrast" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Lum_Contrast" Classes="param-slider" Minimum="0.1" Maximum="3.0" SmallChange="0.05"/>
                                            <TextBox Grid.Column="2" x:Name="Lum_Contrast" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Lum_Sat" Classes="param-label" Text="Sat" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Lum_Sat" Classes="param-slider" Minimum="0.1" Maximum="3.0" SmallChange="0.05"/>
                                            <TextBox Grid.Column="2" x:Name="Lum_Sat" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Lum_Hue" Classes="param-label" Text="Hue" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Lum_Hue" Classes="param-slider" Minimum="-180" Maximum="180" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Lum_Hue" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Lum_GammaY" Classes="param-label" Text="GammaY" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Lum_GammaY" Classes="param-slider" Minimum="0.1" Maximum="3.0" SmallChange="0.05"/>
                                            <TextBox Grid.Column="2" x:Name="Lum_GammaY" Width="70"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── GAMMAC ── -->
                                <Border x:Name="GammacParams" IsVisible="False"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
                                        Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="section-title" Text="GAMMAC"/>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_LockChan" Classes="param-label" Text="LockChan" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_LockChan" Classes="param-slider" Minimum="-3" Maximum="2" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="LockChan" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_LockVal" Classes="param-label" Text="LockVal" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_LockVal" Classes="param-slider" Minimum="0" Maximum="255" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="LockVal" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Scale" Classes="param-label" Text="Scale" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Scale" Classes="param-slider" Minimum="0" Maximum="2" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Scale" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Th" Classes="param-label" Text="Th" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Th" Classes="param-slider" Minimum="0" Maximum="1" SmallChange="0.01"/>
                                            <TextBox Grid.Column="2" x:Name="Th" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_HiTh" Classes="param-label" Text="HiTh" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_HiTh" Classes="param-slider" Minimum="0" Maximum="1" SmallChange="0.01"/>
                                            <TextBox Grid.Column="2" x:Name="HiTh" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_X" Classes="param-label" Text="X" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_X" Classes="param-slider" Minimum="0" Maximum="2000" SmallChange="10"/>
                                            <TextBox Grid.Column="2" x:Name="X" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Y" Classes="param-label" Text="Y" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Y" Classes="param-slider" Minimum="0" Maximum="2000" SmallChange="10"/>
                                            <TextBox Grid.Column="2" x:Name="Y" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_W" Classes="param-label" Text="W" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_W" Classes="param-slider" Minimum="0" Maximum="4000" SmallChange="10"/>
                                            <TextBox Grid.Column="2" x:Name="W" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_H" Classes="param-label" Text="H" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_H" Classes="param-slider" Minimum="0" Maximum="4000" SmallChange="10"/>
                                            <TextBox Grid.Column="2" x:Name="H" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Omin" Classes="param-label" Text="Omin" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Omin" Classes="param-slider" Minimum="0" Maximum="255" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Omin" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Omax" Classes="param-label" Text="Omax" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Omax" Classes="param-slider" Minimum="0" Maximum="255" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Omax" Width="70"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_ShowPreview" Classes="param-label" Text="Show"/>
                                            <Button x:Name="ShowPreview" Width="70" Classes="toggle" Click="OnOptionToggleButtonClick"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Verbosity" Classes="param-label" Text="Verbosity" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Verbosity" Classes="param-slider" Minimum="0" Maximum="6" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Verbosity" Width="70"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── SHARPEN ── -->
                                <Border x:Name="SharpParams" IsVisible="False"
                                        BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0"
                                        Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="section-title" Text="SHARPEN"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_sharp_preset" Classes="param-label" Text="preset"/>
                                            <ComboBox x:Name="sharp_preset"/>
                                        </StackPanel>
                                        <Separator Margin="0,0,0,2"/>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Sharp_Strength" Classes="param-label" Text="Strength" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Sharp_Strength" Classes="param-slider" Minimum="1" Maximum="20" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Sharp_Strength" Width="70"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Sharp_Radius" Classes="param-label" Text="Radius" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Sharp_Radius" Classes="param-slider" Minimum="0.5" Maximum="5.0" SmallChange="0.1"/>
                                            <TextBox Grid.Column="2" x:Name="Sharp_Radius" Width="70"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:Name="Label_Sharp_Mode" Classes="param-label" Text="Mode"/>
                                            <ComboBox x:Name="Sharp_Mode"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="Auto,Auto,70">
                                            <TextBlock Grid.Column="0" x:Name="Label_Sharp_Threshold" Classes="param-label" Text="Threshold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Slider Grid.Column="1" x:Name="Slide_Sharp_Threshold" Classes="param-slider" Minimum="0" Maximum="100" SmallChange="1"/>
                                            <TextBox Grid.Column="2" x:Name="Sharp_Threshold" Width="70"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── CUSTOM FILTER SETTINGS (dynamic) ── -->
                                <StackPanel x:Name="CustomParamPanels" Orientation="Horizontal"/>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ════ RECORD OVERLAY (surimpression) ════ -->
                <Border x:Name="RecordOverlay" IsVisible="False"
                        Grid.Column="0" Grid.ColumnSpan="3"
                        Background="#F0181C28" ZIndex="10"
                        Padding="20,12">
                    <DockPanel HorizontalAlignment="Stretch" Margin="24,0">

                        <!-- ── Title ── -->
                        <TextBlock x:Name="RecordOverlayTitle"
                                   DockPanel.Dock="Top"
                                   Text="⏺ Record"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- ── Bottom bar: Progress + Shutdown + Start ── -->
                        <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,8,0,0">
                            <StackPanel x:Name="RecordProgressPanel" Spacing="2" IsVisible="False">
                                <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
                                    <ProgressBar x:Name="RecordProgressBar" Grid.Column="1"
                                                 Minimum="0" Maximum="100"
                                                 Value="0" Height="10" Foreground="#3B82C4"/>
                                </Grid>
                                <TextBlock x:Name="RecordProgressText" Text=""
                                           FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                                <CheckBox x:Name="ShutdownCheckBox" Content="Shutdown after completion"
                                          FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                          VerticalAlignment="Center"/>
                                <Button x:Name="RecordStartBtn"
                                        Content="▶ Start encoding"
                                        FontSize="13" FontWeight="SemiBold"
                                        Padding="20,5"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Background="#35C156" Foreground="White"
                                        Click="OnRecordStartClick"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ── Main area: two columns (centered, 2/3 width) ── -->
                        <Grid x:Name="RecordSettingsGrid" ColumnDefinitions="0.3*,2*,20,2*,0.3*" Margin="0,4,0,0">

                            <!-- ══ LEFT: Clip list ══ -->
                            <DockPanel Grid.Column="1">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10"
                                            Margin="0,0,0,6">
                                    <TextBlock x:Name="BatchClipListLabel" Text="Clips to encode"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextLabel}"
                                               VerticalAlignment="Center"/>
                                    <CheckBox x:Name="BatchSelectAllCheck" Content="Select all"
                                              FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                              VerticalAlignment="Center"
                                              Click="OnBatchSelectAllClick"/>
                                </StackPanel>
                                <Border Background="#1A2030" BorderBrush="{DynamicResource BorderSubtle}"
                                        BorderThickness="1" CornerRadius="4" Padding="4">
                                    <DockPanel>
                                        <!-- Column headers -->
                                        <Grid DockPanel.Dock="Top" ColumnDefinitions="24,2*,8,2*,8,1.5*" Margin="0,0,0,4">
                                            <TextBlock Grid.Column="1" x:Name="BatchColOriginal" Text="Clip"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="3" x:Name="BatchColRenamed" Text="Renamed"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="5" x:Name="BatchColPreset" Text="Preset"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </Grid>
                                        <Border Height="1" DockPanel.Dock="Top"
                                                Background="{DynamicResource BorderSubtle}" Margin="0,0,0,4"/>
                                        <ScrollViewer>
                                            <StackPanel x:Name="BatchClipList" Spacing="2"/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </DockPanel>

                            <!-- ══ RIGHT: Encoding settings (preset + params grouped) ══ -->
                            <Border Grid.Column="3"
                                    Background="#10FFFFFF" BorderBrush="{DynamicResource BorderSubtle}"
                                    BorderThickness="1" CornerRadius="6" Padding="20,8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="10">

                                    <!-- Encoding preset -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="RecordPresetLabel" Text="Preset"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextLabel}"/>
                                        <Grid ColumnDefinitions="*,6,Auto,6,Auto" MaxWidth="320" HorizontalAlignment="Left">
                                            <ComboBox x:Name="RecordPresetCombo" Grid.Column="0"
                                                      FontSize="12" HorizontalAlignment="Stretch"
                                                      IsEditable="True"/>
                                            <Button x:Name="RecordPresetSaveBtn" Grid.Column="2"
                                                    Content="Save" FontSize="11" Height="26" MinWidth="50" Padding="8,0"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Click="OnRecordPresetSaveClick"/>
                                            <Button x:Name="RecordPresetDeleteBtn" Grid.Column="4"
                                                    Content="Del" FontSize="11" Height="26" MinWidth="42" Padding="8,0"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Click="OnRecordPresetDeleteClick"/>
                                        </Grid>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource BorderSubtle}" Margin="0,2"/>

                                    <!-- Output directory -->
                                    <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock x:Name="RecordDirLabel" Text="Output directory"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}" />
                                            <TextBlock x:Name="RecordDiskSpace" Text=""
                                                       FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="400,6,Auto,4,Auto">
                                            <TextBox x:Name="RecordDir" Grid.Column="0" FontSize="12" Height="28" TextAlignment="Left"
                                                     Watermark="C:\output"/>
                                            <Button x:Name="RecordDirPickBtn" Grid.Column="2" Content="…" FontSize="13"
                                                    Width="28" Height="28"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Click="OnRecordDirPickClick"/>
                                            <Button Grid.Column="4" Content="📂" FontSize="13"
                                                    Width="28" Height="28"
                                                    ToolTip.Tip="Open directory"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Click="OnRecordDirOpenClick"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Encoder + Container -->
                                    <Grid ColumnDefinitions="3*,20,2*,*">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="RecordEncoderLabel" Text="Encoder"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <ComboBox x:Name="RecordEncoder" FontSize="12"
                                                      HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="x264" Tag="x264"/>
                                                <ComboBoxItem Content="x265" Tag="x265"/>
                                                <ComboBoxItem Content="FFV1 (lossless)" Tag="ffv1"/>
                                                <ComboBoxItem Content="UT Video (lossless)" Tag="utvideo"/>
                                                <ComboBoxItem Content="ProRes" Tag="prores"/>
                                                <ComboBoxItem Content="TIFF sequence" Tag="tiff"/>
                                                <ComboBoxItem Content="PNG sequence" Tag="png"/>
                                                <ComboBoxItem Content="JPEG sequence" Tag="jpg"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <TextBlock x:Name="RecordContainerLabel" Text="Container"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <ComboBox x:Name="RecordContainer" FontSize="12"
                                                      HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="MKV" Tag="mkv"/>
                                                <ComboBoxItem Content="MP4" Tag="mp4"/>
                                                <ComboBoxItem Content="AVI" Tag="avi"/>
                                                <ComboBoxItem Content="MOV" Tag="mov"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Resolution + Chroma -->
                                    <Grid ColumnDefinitions="3*,20,2*,*">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="RecordResizeLabel" Text="Resolution"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <ComboBox x:Name="RecordResize" FontSize="12"
                                                      HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="Original" Tag="original"/>
                                                <ComboBoxItem Content="1080p" Tag="1080"/>
                                                <ComboBoxItem Content="720p" Tag="720"/>
                                                <ComboBoxItem Content="576p" Tag="576"/>
                                                <ComboBoxItem Content="480p" Tag="480"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel x:Name="RecordChromaPanel" Grid.Column="2" Spacing="2">
                                            <TextBlock x:Name="RecordChromaLabel" Text="Chroma"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <ComboBox x:Name="RecordChroma" FontSize="12"
                                                      HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="4:2:0" Tag="yuv420p"/>
                                                <ComboBoxItem Content="4:2:2" Tag="yuv422p"/>
                                                <ComboBoxItem Content="4:4:4" Tag="yuv444p"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Quality mode + CRF/Bitrate (hidden for lossless) -->
                                    <Grid x:Name="RecordQualityPanel" ColumnDefinitions="3*,20,2*,*">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock x:Name="RecordQualityModeLabel" Text="Quality mode"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <ComboBox x:Name="RecordQualityMode" FontSize="12"
                                                      HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="CRF" Tag="crf"/>
                                                <ComboBoxItem Content="Bitrate (Mb/s)" Tag="bitrate"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel x:Name="RecordCrfPanel" Grid.Column="2" Spacing="2">
                                            <TextBlock x:Name="RecordCrfLabel" Text="CRF"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <Grid ColumnDefinitions="*,6,Auto" Height="28">
                                                <Slider x:Name="RecordCrfSlider" Grid.Column="0"
                                                        Classes="param-slider"
                                                        Minimum="0" Maximum="51" Value="18"
                                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                                        VerticalAlignment="Center"
                                                        Width="200" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="RecordCrfValue" Grid.Column="2"
                                                           Text="18" FontSize="12" MinWidth="20"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel x:Name="RecordBitratePanel" Grid.Column="2" Spacing="2"
                                                    IsVisible="False">
                                            <TextBlock x:Name="RecordBitrateLabel" Text="Bitrate (Mb/s)"
                                                       FontSize="12" Foreground="{DynamicResource TextLabel}"/>
                                            <TextBox x:Name="RecordBitrate" FontSize="12" Height="28"
                                                     Watermark="20"/>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>

            </Grid>
        </Border>

        </Grid><!-- fin Grid vidéo+splitter+panneau bas -->

    </DockPanel>
</Window>
