<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       x:Class="AvyScanLab.Views.CustomFilterDialog"
       Width="850"
       Height="800"
       MinWidth="650"
       MinHeight="500"
       CanResize="True"
       WindowStartupLocation="CenterOwner"
       SystemDecorations="BorderOnly"
       ShowInTaskbar="False"
       Background="{DynamicResource BgDeep}"
       Icon="/Assets/Ico.ico">

   <Window.Styles>
       <Style Selector="Button.dialog-btn /template/ ContentPresenter">
           <Setter Property="Background" Value="{DynamicResource BgHeader}"/>
       </Style>
       <Style Selector="Button.dialog-btn:pointerover /template/ ContentPresenter">
           <Setter Property="Background" Value="{DynamicResource BgHover}"/>
       </Style>
       <Style Selector="Button#DeleteBtn /template/ ContentPresenter">
           <Setter Property="Background" Value="#5A2E2E"/>
           <Setter Property="Foreground" Value="White"/>
       </Style>
       <Style Selector="Button#DeleteBtn:pointerover /template/ ContentPresenter">
           <Setter Property="Background" Value="#7A3E3E"/>
           <Setter Property="Foreground" Value="White"/>
       </Style>
       <Style Selector="Button#SaveBtn /template/ ContentPresenter">
           <Setter Property="Background" Value="#2E5A3D"/>
           <Setter Property="Foreground" Value="White"/>
       </Style>
       <Style Selector="Button#SaveBtn:pointerover /template/ ContentPresenter">
           <Setter Property="Background" Value="#3E7A4D"/>
           <Setter Property="Foreground" Value="White"/>
       </Style>
       <Style Selector="Button#CloseXButton /template/ ContentPresenter">
           <Setter Property="Background" Value="Transparent"/>
       </Style>
       <Style Selector="Button#CloseXButton:pointerover /template/ ContentPresenter">
           <Setter Property="Background" Value="Transparent"/>
       </Style>
       <Style Selector="Button#CloseXButton:pointerover">
           <Setter Property="Foreground" Value="#C05050"/>
       </Style>
   </Window.Styles>

   <Border BorderBrush="{DynamicResource AccentBlue}" BorderThickness="2" Margin="4"
           Background="{DynamicResource BgPanel}"
           BoxShadow="0 4 16 0 #40000000"
           CornerRadius="4">
       <Grid RowDefinitions="Auto,*,Auto">

           <!-- Title bar -->
           <Border x:Name="TitleBar"
                   Grid.Row="0"
                   Height="34"
                   Padding="14,0,6,0"
                   Background="{DynamicResource BgDeep}"
                   BorderBrush="{DynamicResource BorderSubtle}"
                   BorderThickness="0,0,0,1">
               <Grid ColumnDefinitions="*,Auto">
                   <TextBlock x:Name="TitleText"
                              Grid.Column="0"
                              Text="CUSTOM FILTER"
                              FontSize="10"
                              FontFamily="Consolas,Cascadia Code,monospace"
                              Foreground="{DynamicResource TextPrimary}"
                              LetterSpacing="2"
                              VerticalAlignment="Center"/>
                   <Button x:Name="CloseXButton"
                           Grid.Column="1"
                           Width="28" Height="28"
                           Padding="0"
                           Background="Transparent"
                           BorderThickness="0"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"
                           Content="&#x2715;"/>
               </Grid>
           </Border>

           <!-- Main content: code (3*) + splitter + params (2*) -->
           <Grid x:Name="MainContentGrid" Grid.Row="1" RowDefinitions="Auto,3*,4,2*">

               <!-- Top section: Name, Position, DLLs -->
               <ScrollViewer Grid.Row="0"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             MaxHeight="320">
                   <StackPanel Margin="20,14,20,8" Spacing="24">

                       <!-- Name + RegionDraw -->
                       <StackPanel Spacing="3">
                           <TextBlock x:Name="FilterNameLabel"
                                      Text="Filter name"
                                      FontSize="13" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextLabel}"/>
                           <Grid ColumnDefinitions="*,Auto">
                               <TextBox x:Name="FilterNameBox"
                                        Grid.Column="0"
                                        Watermark="My custom filter"
                                        FontSize="12"
                                        Background="{DynamicResource BgInput}"
                                        Foreground="{DynamicResource TextSecondary}"
                                        BorderBrush="{DynamicResource BorderSubtle}"/>
                               <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                          VerticalAlignment="Center" Margin="12,0,0,0">
                                   <CheckBox x:Name="RegionDrawCheck"
                                             FontSize="12"
                                             Foreground="{DynamicResource TextSecondary}"
                                             VerticalAlignment="Center"
                                             Content="Region draw"/>
                                   <ComboBox x:Name="RegionDrawModeCombo"
                                             FontSize="11" Width="120"
                                             IsVisible="False"
                                             VerticalAlignment="Center"
                                             Background="{DynamicResource BgInput}"
                                             Foreground="{DynamicResource TextSecondary}"
                                             BorderBrush="{DynamicResource BorderSubtle}"/>
                               </StackPanel>
                           </Grid>
                       </StackPanel>

                       <!-- DLLs + Scripts on 2 columns -->
                       <Grid ColumnDefinitions="*,16,*">
                           <!-- DLLs -->
                           <StackPanel Grid.Column="0" Spacing="3">
                               <Grid ColumnDefinitions="*,Auto">
                                   <TextBlock x:Name="PluginsLabel"
                                              Grid.Column="0"
                                              Text="Plugins (TryLoadPlugin)"
                                              FontSize="13" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextLabel}"
                                              VerticalAlignment="Center"/>
                                   <Button x:Name="AddDllBtn"
                                           Grid.Column="1"
                                           Content="+ Add DLL..."
                                           FontSize="11"
                                           Padding="8,3"
                                           Classes="dialog-btn"
                                           Foreground="{DynamicResource TextPrimary}"
                                           BorderBrush="{DynamicResource BorderSubtle}"
                                           BorderThickness="1"/>
                               </Grid>
                               <StackPanel x:Name="DllListPanel" Spacing="2"/>
                           </StackPanel>

                           <!-- Scripts (.avsi) -->
                           <StackPanel Grid.Column="2" Spacing="3">
                               <Grid ColumnDefinitions="*,Auto">
                                   <TextBlock x:Name="ScriptsLabel"
                                              Grid.Column="0"
                                              Text="Scripts (Import .avsi)"
                                              FontSize="13" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextLabel}"
                                              VerticalAlignment="Center"/>
                                   <Button x:Name="AddScriptBtn"
                                           Grid.Column="1"
                                           Content="+ Add AVSI..."
                                           FontSize="11"
                                           Padding="8,3"
                                           Classes="dialog-btn"
                                           Foreground="{DynamicResource TextPrimary}"
                                           BorderBrush="{DynamicResource BorderSubtle}"
                                           BorderThickness="1"/>
                               </Grid>
                               <StackPanel x:Name="ScriptListPanel" Spacing="2"/>
                           </StackPanel>
                       </Grid>
                   </StackPanel>
               </ScrollViewer>

               <!-- Code editor (stretches with window) -->
               <Border Grid.Row="1"
                       Padding="20,16">
                   <Grid RowDefinitions="Auto,*">
                       <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                           <StackPanel Grid.Column="0" Spacing="1">
                               <TextBlock x:Name="CodeLabel"
                                          Text="AviSynth code"
                                          FontSize="13" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextLabel}"/>
                               <TextBlock x:Name="CodeHint"
                                          Text="Use 'c' as the clip variable, {name} for parameters."
                                          FontSize="10"
                                          Foreground="{DynamicResource TextPrimary}"/>
                           </StackPanel>
                           <Button x:Name="PreviewBtn"
                                   Grid.Column="1"
                                   Content="&#x25B6; Preview"
                                   FontSize="11"
                                   Padding="8,3"
                                   Background="{DynamicResource BgHeader}"
                                   Foreground="{DynamicResource AccentBlue}"
                                   BorderBrush="{DynamicResource BorderSubtle}"
                                   BorderThickness="1"
                                   VerticalAlignment="Center"
                                   HorizontalContentAlignment="Center"
                                   VerticalContentAlignment="Center"/>
                       </Grid>
                       <TextBox x:Name="CodeBox"
                                Grid.Row="1"
                                AcceptsReturn="True"
                                TextWrapping="NoWrap"
                                FontFamily="Consolas,Courier New,monospace"
                                FontSize="12"
                                Background="{DynamicResource BgInput}"
                                Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                Watermark="c = MyFilter(c, strength={sigma}, mode={bt_mode})"/>
                   </Grid>
               </Border>

               <!-- GridSplitter between code and parameters -->
               <GridSplitter Grid.Row="2"
                             Height="4"
                             HorizontalAlignment="Stretch"
                             Background="{DynamicResource BorderSubtle}"
                             ResizeDirection="Rows"/>

               <!-- Parameters section (resizable) -->
               <ScrollViewer Grid.Row="3"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                   <StackPanel Margin="20,16,20,10" Spacing="2">
                       <TextBlock x:Name="ParamsLabel"
                                  Text="Parameters"
                                  FontSize="13" FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextLabel}"/>
                       <TextBlock x:Name="ParamsHint"
                                  Text="Detected from {placeholders} in code above."
                                  FontSize="10"
                                  Foreground="{DynamicResource TextPrimary}"
                                  Margin="0,0,0,2"/>
                       <StackPanel x:Name="ControlsPanel" Spacing="4"/>
                   </StackPanel>
               </ScrollViewer>

           </Grid>

           <!-- Footer -->
           <Border Grid.Row="2"
                   BorderBrush="{DynamicResource BorderSubtle}"
                   BorderThickness="0,1,0,0"
                   Padding="14,10">
               <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                   <!-- Delete (left) -->
                   <Button x:Name="DeleteBtn"
                           Grid.Column="0"
                           Content="Delete"
                           MinWidth="90" Height="28"
                           Padding="12,0"
                           Background="#5A2E2E"
                           Foreground="White"
                           BorderBrush="#C05050"
                           BorderThickness="1"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"/>

                   <!-- Export (center-left) -->
                   <Button x:Name="ExportBtn"
                           Grid.Column="1"
                           Content="&#x2191; Export"
                           MinWidth="90" Height="28"
                           Padding="12,0"
                           Margin="10,0,0,0"
                           Classes="dialog-btn"
                           Foreground="{DynamicResource TextPrimary}"
                           BorderBrush="{DynamicResource BorderSubtle}"
                           BorderThickness="1"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"/>

                   <!-- Duplicate -->
                   <Button x:Name="DuplicateBtn"
                           Grid.Column="2"
                           Content="&#x2750; Duplicate"
                           MinWidth="90" Height="28"
                           Padding="12,0"
                           Margin="10,0,0,0"
                           Classes="dialog-btn"
                           Foreground="{DynamicResource TextPrimary}"
                           BorderBrush="{DynamicResource BorderSubtle}"
                           BorderThickness="1"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"/>

                   <!-- Help -->
                   <Button x:Name="HelpBtn"
                           Grid.Column="3"
                           Content="? Help"
                           MinWidth="80" Height="28"
                           Padding="12,0"
                           Margin="10,0,0,0"
                           Classes="dialog-btn"
                           Foreground="{DynamicResource TextPrimary}"
                           BorderBrush="{DynamicResource BorderSubtle}"
                           BorderThickness="1"
                           HorizontalContentAlignment="Center"
                           VerticalContentAlignment="Center"/>

                   <!-- Cancel + Save (right) -->
                   <StackPanel Grid.Column="5"
                               Orientation="Horizontal"
                               Spacing="10">
                       <Button x:Name="CancelBtn"
                               Content="Cancel"
                               MinWidth="90" Height="28"
                               Padding="12,0"
                               Classes="dialog-btn"
                               Foreground="{DynamicResource TextPrimary}"
                               BorderBrush="{DynamicResource BorderSubtle}"
                               BorderThickness="1"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"/>
                       <Button x:Name="SaveBtn"
                               Content="Save"
                               MinWidth="90" Height="28"
                               Padding="12,0"
                               Background="#2E5A3D"
                               Foreground="White"
                               BorderBrush="{DynamicResource AccentGreen}"
                               BorderThickness="1"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"/>
                   </StackPanel>
               </Grid>
           </Border>

       </Grid>
   </Border>
</Window>
