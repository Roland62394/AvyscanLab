<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CleanScan.Views.SplashWindow"
        Width="450"
        Height="350"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Background="Black"
        Icon="/Assets/Ico.ico">
    <Border BorderBrush="#3A3A3A">
        <Grid>
            <Image Width="450"
                   Height="350"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Source="avares://CleanScan/Assets/Logo.png"
                   Stretch="None"/>
            <TextBlock Text="Trial version"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#FFD54F"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,36"/>
            <TextBlock Text="RC 1.0.0"
                       FontSize="14"
                       Foreground="White"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Margin="12,0,0,10"/>
            <TextBlock Text="© ScanFilm 2026"
                       FontSize="14"
                       Foreground="White"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,12,10"/>
        </Grid>
    </Border>
</Window>
